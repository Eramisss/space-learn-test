# ---------- Django ----------
# Сгенерируйте через: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=replace-me-with-strong-random-key

# В проде всегда False
DEBUG=False

# Через запятую: домен и/или IP сервера
ALLOWED_HOSTS=localhost,127.0.0.1,example.com

# Полные URL с http:// или https:// (нужно для POST на /admin/, /api/auth/)
CSRF_TRUSTED_ORIGINS=http://localhost,http://example.com

# Origin-ы, которым разрешён CORS. В одно-origin деплое за Nginx можно оставить пустым.
CORS_ALLOWED_ORIGINS=

# ---------- PostgreSQL ----------
DB_NAME=spaced_repetition
DB_USER=postgres
DB_PASSWORD=change-me-strong-password
DB_HOST=db
DB_PORT=5432
